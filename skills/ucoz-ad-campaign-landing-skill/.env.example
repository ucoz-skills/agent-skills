# =============================================================================
# Copy this file as .env.local and fill in the values.
# Do NOT commit .env.local — it is in .gitignore.
# The agent reads variables from the environment via Shell for curl calls.
# =============================================================================


# =============================================================================
# YANDEX CLOUD — Search API v2 (Wordstat + SERP)
# Documentation: references/RESEARCH.md §Wordstat
# Create key: aistudio.yandex.ru → API keys, scope: yc.search-api.execute
# Folder ID: console.yandex.cloud → folder → copy b1g...
# =============================================================================

YANDEX_SEARCH_API_KEY=AQVN...
YANDEX_FOLDER_ID=b1g...


# =============================================================================
# YANDEX DIRECT — API v5
# Documentation: references/DIRECT_API.md
# OAuth: oauth.yandex.ru → Client ID with direct:api scope
# Get token: instructions in DIRECT_API.md §OAuth
# =============================================================================

YANDEX_DIRECT_TOKEN=AQAAAA...

# Advertiser login (only when working via agency account):
# YANDEX_DIRECT_CLIENT_LOGIN=advertiser-login

# ── API ACCESS MODE ───────────────────────────────────────────────────────────
#
#   TEST (Sandbox):
#     YANDEX_DIRECT_USE_SANDBOX=1
#     → Host: api-sandbox.direct.yandex.com
#     → Campaigns in isolated environment, no spend
#
#   PRODUCTION:
#     YANDEX_DIRECT_USE_SANDBOX=0  (or omit)
#     → Host: api.direct.yandex.com
#     → Real campaigns — agent asks permission before each push
#
YANDEX_DIRECT_USE_SANDBOX=1
# YANDEX_DIRECT_USE_SANDBOX=0


# =============================================================================
# GOOGLE ADS — API
# Documentation: references/GOOGLE_ADS.md §OAuth setup
# Developer token: Google Ads → Tools → API Center
# refresh_token: OAuth Playground (instructions in GOOGLE_ADS.md §Step 3)
# =============================================================================

GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-...
GOOGLE_ADS_REFRESH_TOKEN=1//...

# ── API ACCESS MODE ───────────────────────────────────────────────────────────
#
#   TEST:
#     GOOGLE_ADS_CUSTOMER_ID=<test account ID>
#     → Requires a test customer created for debugging
#     → Agent shows payload before sending (dry-run description)
#
#   PRODUCTION:
#     GOOGLE_ADS_CUSTOMER_ID=<live account ID>
#     → Campaigns created in PAUSED status
#     → Agent must ask permission before push
#
GOOGLE_ADS_CUSTOMER_ID=0000000000

# MCC (manager account):
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=0000000000
