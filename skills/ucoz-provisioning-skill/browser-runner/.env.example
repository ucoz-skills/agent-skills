# uCoz account login for browser provisioning. Do not commit real values.
UCOZ_EMAIL=you@example.com
UCOZ_PASSWORD=

# Existing site mode
# MODE=existing
# BASE_URL=https://example.ucoz.net

# New site mode after user confirmation
# MODE=new
# SITE_PREFIX=my-site
# DOMAIN=<zone from live uCoz UI>
# PRESET_MATCH=<card chosen by user from live uCoz UI>
# SITE_TITLE=My uCoz Site

# Optional uAPI setup after module confirmation (FTP via MCP ftp_tool)
# SETUP_UAPI=true
# KEY_NAME=MCP site connection

# Debug
# HEADLESS=true
# OUTPUT_SECRETS=false
